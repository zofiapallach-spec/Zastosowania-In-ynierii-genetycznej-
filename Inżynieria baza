function setFilter(filter, btn) {
  currentFilter = filter;
  document.querySelectorAll('.tag').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  applyFilter();
}

function applyFilter() {
  if (currentFilter === 'all') filteredQuestions = [...questions];
  else if (currentFilter === 'open') filteredQuestions = questions.filter(q => q.type === 'open');
  else filteredQuestions = questions.filter(q => q.topic === currentFilter);
  flashIdx = 0;
  isFlipped = false;
  if (currentMode === 'flashcard') renderFlashcard();
  else if (currentMode === 'quiz') startQuiz();
  else if (currentMode === 'browse') renderBrowse();
}

// ─── MODE ─────────────────────────────────────────────────────────────────────
function setMode(mode) {
  currentMode = mode;
  document.querySelectorAll('.mode-btn').forEach((b, i) => {
    b.classList.toggle('active', ['flashcard','quiz','browse'][i] === mode);
  });
  document.getElementById('flashcardMode').style.display = mode === 'flashcard' ? 'block' : 'none';
  document.getElementById('quizMode').style.display = mode === 'quiz' ? 'block' : 'none';
  document.getElementById('browseMode').style.display = mode === 'browse' ? 'block' : 'none';
  if (mode === 'quiz') startQuiz();
  else if (mode === 'browse') renderBrowse();
  else { flashIdx = 0; isFlipped = false; renderFlashcard(); }
}

// ─── FLASHCARD ────────────────────────────────────────────────────────────────
function renderFlashcard() {
  if (!filteredQuestions.length) return;
  const q = filteredQuestions[flashIdx];
  const card = document.getElementById('flashcard');
  card.classList.remove('flipped');
  isFlipped = false;
  document.getElementById('ratingBtns').style.display = 'none';

  const pct = ((flashIdx + 1) / filteredQuestions.length) * 100;
  document.getElementById('flashProgress').style.width = pct + '%';

  document.getElementById('cardNum').textContent = `PYTANIE ${String(q.id).padStart(2,'0')} / ${filteredQuestions.length}`;
  document.getElementById('cardNumBack').textContent = `PYTANIE ${String(q.id).padStart(2,'0')} / ${filteredQuestions.length}`;
  document.getElementById('progressText').textContent = `${flashIdx+1} / ${filteredQuestions.length}`;

  const typeTag = document.getElementById('cardTypeTag');
  typeTag.textContent = q.type === 'mcq' ? 'MCQ' : 'PYTANIE OTWARTE';
  typeTag.className = `card-tag ${q.type}`;

  document.getElementById('cardQuestion').textContent = q.q;
  document.getElementById('cardAnswer').textContent = q.a;
  document.getElementById('cardExplanation').textContent = q.exp;

  document.getElementById('prevBtn').disabled = flashIdx === 0;
  document.getElementById('nextBtn').disabled = flashIdx === filteredQuestions.length - 1;

  updateStats();
}

function flipCard() {
  isFlipped = !isFlipped;
  document.getElementById('flashcard').classList.toggle('flipped', isFlipped);
  if (isFlipped) {
    document.getElementById('ratingBtns').style.display = 'grid';
    studied.add(filteredQuestions[flashIdx].id);
    updateStats();
  } else {
    document.getElementById('ratingBtns').style.display = 'none';
  }
}

function nextCard() {
  if (flashIdx < filteredQuestions.length - 1) {
    flashIdx++;
    renderFlashcard();
  }
}

function prevCard() {
  if (flashIdx > 0) {
    flashIdx--;
    renderFlashcard();
  }
}

function rateCard(rating) {
  const q = filteredQuestions[flashIdx];
  ratings[q.id] = rating;
  if (flashIdx < filteredQuestions.length - 1) {
    flashIdx++;
    renderFlashcard();
  }
}

// ─── QUIZ ─────────────────────────────────────────────────────────────────────
function startQuiz() {
  document.getElementById('resultsScreen').classList.remove('show');
  document.getElementById('quizContainer').style.display = 'block';

  const mcqOnly = filteredQuestions.filter(q => q.type === 'mcq' && q.options);
  quizQuestions = shuffle([...mcqOnly]).slice(0, Math.min(15, mcqOnly.length));
  quizIdx = 0; quizCorrect = 0; quizIncorrect = 0;
  renderQuizQuestion();
}

function renderQuizQuestion() {
  if (quizIdx >= quizQuestions.length) { showResults(); return; }
  const q = quizQuestions[quizIdx];
  quizAnswered = false;

  const pct = (quizIdx / quizQuestions.length) * 100;
  document.getElementById('quizProgress').style.width = pct + '%';
  document.getElementById('quizNum').textContent = `PYTANIE ${quizIdx+1} / ${quizQuestions.length}`;
  document.getElementById('quizQuestion').textContent = q.q;

  const grid = document.getElementById('optionsGrid');
  grid.innerHTML = '';
  const letters = ['A','B','C','D'];
  q.options.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.innerHTML = `<span class="option-letter">${letters[i]}</span>${opt}`;
    btn.onclick = () => selectAnswer(i, q);
    grid.appendChild(btn);
  });

  document.getElementById('quizExplanation').className = 'quiz-explanation';
  document.getElementById('nextQuizBtn').className = 'next-btn';
}

function selectAnswer(idx, q) {
  if (quizAnswered) return;
  quizAnswered = true;
  const btns = document.querySelectorAll('.option-btn');

  btns.forEach((btn, i) => {
    btn.disabled = true;
    if (i === q.correct) btn.classList.add('correct');
    else if (i === idx && idx !== q.correct) btn.classList.add('incorrect');
  });

  if (idx === q.correct) quizCorrect++;
  else quizIncorrect++;

  const expEl = document.getElementById('quizExplanation');
  expEl.innerHTML = `<strong>${idx === q.correct ? '✓ Poprawnie!' : '✗ Błędna odpowiedź.'}</strong> ${q.exp}`;
  expEl.className = 'quiz-explanation show';

  document.getElementById('nextQuizBtn').className = 'next-btn show';
  updateStats();
}

function nextQuizQuestion() {
  quizIdx++;
  renderQuizQuestion();
}

function showResults() {
  document.getElementById('quizContainer').style.display = 'none';
  const screen = document.getElementById('resultsScreen');
  screen.classList.add('show');
  const total = quizCorrect + quizIncorrect;
  const pct = total ? Math.round((quizCorrect / total) * 100) : 0;
  document.getElementById('resultsScore').textContent = pct + '%';
  document.getElementById('correctCount').textContent = quizCorrect;
  document.getElementById('incorrectCount').textContent = quizIncorrect;
  document.getElementById('quizTotal').textContent = quizQuestions.length;
  document.getElementById('quizScore').textContent = pct + '%';
}

// ─── BROWSE ───────────────────────────────────────────────────────────────────
function renderBrowse(searchText = '') {
  const grid = document.getElementById('browseGrid');
  grid.innerHTML = '';
  const search = searchText.toLowerCase();
  const toShow = filteredQuestions.filter(q =>
    !search || q.q.toLowerCase().includes(search) || q.a.toLowerCase().includes(search) || q.exp.toLowerCase().includes(search)
  );
  toShow.forEach(q => {
    const item = document.createElement('div');
    item.className = 'browse-item';
    item.innerHTML = `
      <div class="browse-header" onclick="toggleBrowse(this)">
        <span class="browse-num">Pyt. ${q.id}</span>
        <span class="browse-q">${q.q}</span>
        <span class="browse-toggle">▼</span>
      </div>
      <div class="browse-body">
        <div class="browse-answer">✓ ${q.a}</div>
        <div class="browse-explanation">${q.exp}</div>
      </div>`;
    grid.appendChild(item);
  });
  if (!toShow.length) {
    grid.innerHTML = '<div style="color:var(--muted);text-align:center;padding:40px;font-family:Space Mono,monospace;font-size:13px;">Brak wyników</div>';
  }
}

function toggleBrowse(header) {
  const item = header.parentElement;
  item.classList.toggle('open');
}

function filterBrowse(text) {
  renderBrowse(text);
}

// ─── UTILS ────────────────────────────────────────────────────────────────────
function shuffle(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

function updateStats() {
  document.getElementById('studiedCount').textContent = studied.size;
  document.getElementById('totalCount').textContent = filteredQuestions.length;
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
renderFlashcard();
</script>
</body>
</html>
