<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Inżynieria Genetyczna – Baza Egzaminacyjna</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;700;800&display=swap');

  :root {
    --bg: #0a0e1a;
    --surface: #111827;
    --surface2: #1a2235;
    --accent: #00e5a0;
    --accent2: #3b82f6;
    --accent3: #f59e0b;
    --danger: #ef4444;
    --text: #e2e8f0;
    --muted: #64748b;
    --border: #1e293b;
    --correct: #10b981;
    --incorrect: #ef4444;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Syne', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Background grid */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,160,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,160,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* ── HEADER ── */
  header {
    position: relative;
    z-index: 10;
    padding: 24px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    background: rgba(10,14,26,0.9);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-icon {
    width: 36px; height: 36px;
    background: var(--accent);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
  }

  .logo-text { font-size: 13px; font-family: 'Space Mono', monospace; color: var(--muted); }
  .logo-text strong { display: block; color: var(--text); font-size: 15px; }

  .header-stats {
    display: flex; gap: 24px; align-items: center;
  }

  .stat-chip {
    display: flex; align-items: center; gap: 8px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: var(--muted);
  }

  .stat-chip span { color: var(--accent); font-weight: 700; font-size: 16px; }

  /* ── MAIN LAYOUT ── */
  .app {
    position: relative; z-index: 1;
    max-width: 960px;
    margin: 0 auto;
    padding: 32px 24px;
  }

  /* ── MODE SELECTOR ── */
  .mode-selector {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }

  .mode-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    cursor: pointer;
    text-align: center;
    transition: all 0.2s;
    color: var(--text);
    font-family: 'Syne', sans-serif;
  }

  .mode-btn:hover { border-color: var(--accent); transform: translateY(-2px); }
  .mode-btn.active {
    border-color: var(--accent);
    background: rgba(0,229,160,0.08);
    box-shadow: 0 0 20px rgba(0,229,160,0.1);
  }

  .mode-btn .mode-icon { font-size: 24px; margin-bottom: 8px; }
  .mode-btn .mode-name { font-weight: 700; font-size: 14px; }
  .mode-btn .mode-desc { font-size: 11px; color: var(--muted); margin-top: 4px; }

  /* ── FILTER BAR ── */
  .filter-bar {
    display: flex; gap: 8px; flex-wrap: wrap;
    margin-bottom: 24px;
    align-items: center;
  }

  .filter-label { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--muted); margin-right: 4px; }

  .tag {
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--border);
    font-size: 11px;
    cursor: pointer;
    transition: all 0.2s;
    background: var(--surface);
    color: var(--muted);
    font-family: 'Space Mono', monospace;
  }

  .tag:hover { border-color: var(--accent2); color: var(--accent2); }
  .tag.active { background: var(--accent2); border-color: var(--accent2); color: white; }

  /* ── FLASHCARD MODE ── */
  .flashcard-container {
    perspective: 1200px;
    margin-bottom: 24px;
  }

  .flashcard {
    width: 100%;
    min-height: 320px;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }

  .flashcard.flipped { transform: rotateY(180deg); }

  .card-face {
    position: absolute; inset: 0;
    backface-visibility: hidden;
    border-radius: 16px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 320px;
  }

  .card-front {
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .card-back {
    background: linear-gradient(135deg, rgba(0,229,160,0.05), rgba(59,130,246,0.05));
    border: 1px solid var(--accent);
    transform: rotateY(180deg);
  }

  .card-number {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    margin-bottom: 16px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .card-question {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.5;
    margin-bottom: 16px;
  }

  .card-hint {
    font-size: 12px;
    color: var(--muted);
    font-family: 'Space Mono', monospace;
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .card-answer-label {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 2px;
    margin-bottom: 12px;
  }

  .card-answer {
    font-size: 17px;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 16px;
    line-height: 1.4;
  }

  .card-explanation {
    font-size: 13px;
    color: #94a3b8;
    line-height: 1.7;
    border-top: 1px solid var(--border);
    padding-top: 16px;
    max-height: 180px;
    overflow-y: auto;
  }

  .card-explanation::-webkit-scrollbar { width: 4px; }
  .card-explanation::-webkit-scrollbar-track { background: transparent; }
  .card-explanation::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .card-tag {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 10px;
    font-family: 'Space Mono', monospace;
    border: 1px solid;
    margin-bottom: 12px;
  }

  .card-tag.mcq { border-color: var(--accent2); color: var(--accent2); }
  .card-tag.open { border-color: var(--accent3); color: var(--accent3); }

  /* flashcard nav */
  .card-nav {
    display: flex; gap: 12px; justify-content: center; align-items: center;
    margin-bottom: 16px;
  }

  .nav-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 10px 24px;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.2s;
  }

  .nav-btn:hover { border-color: var(--accent); color: var(--accent); }
  .nav-btn:disabled { opacity: 0.3; cursor: default; }

  .progress-text {
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    color: var(--muted);
    min-width: 80px;
    text-align: center;
  }

  /* flashcard rating buttons */
  .rating-btns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 12px;
  }

  .rating-btn {
    padding: 10px;
    border-radius: 8px;
    border: 1px solid;
    cursor: pointer;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 13px;
    transition: all 0.2s;
    background: transparent;
  }

  .rating-btn.easy { border-color: var(--correct); color: var(--correct); }
  .rating-btn.easy:hover { background: var(--correct); color: #0a0e1a; }
  .rating-btn.medium { border-color: var(--accent3); color: var(--accent3); }
  .rating-btn.medium:hover { background: var(--accent3); color: #0a0e1a; }
  .rating-btn.hard { border-color: var(--incorrect); color: var(--incorrect); }
  .rating-btn.hard:hover { background: var(--incorrect); color: white; }

  /* ── QUIZ MODE ── */
  .quiz-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px;
    margin-bottom: 20px;
    animation: slideIn 0.3s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .quiz-question {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.5;
    margin-bottom: 28px;
  }

  .options-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .option-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 18px;
    cursor: pointer;
    text-align: left;
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    color: var(--text);
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .option-btn:hover:not(:disabled) { border-color: var(--accent2); color: var(--accent2); }
  .option-btn.correct { border-color: var(--correct); background: rgba(16,185,129,0.1); color: var(--correct); }
  .option-btn.incorrect { border-color: var(--incorrect); background: rgba(239,68,68,0.1); color: var(--incorrect); }
  .option-btn.revealed { border-color: var(--correct); background: rgba(16,185,129,0.05); color: var(--correct); }
  .option-btn:disabled { cursor: default; }

  .option-letter {
    width: 28px; height: 28px; min-width: 28px;
    border-radius: 6px;
    border: 1px solid currentColor;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    font-weight: 700;
  }

  .quiz-explanation {
    margin-top: 20px;
    padding: 16px;
    background: rgba(0,229,160,0.04);
    border: 1px solid rgba(0,229,160,0.15);
    border-radius: 10px;
    font-size: 13px;
    color: #94a3b8;
    line-height: 1.7;
    display: none;
  }

  .quiz-explanation.show { display: block; animation: fadeIn 0.3s ease; }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .quiz-explanation strong { color: var(--accent); }

  .next-btn {
    display: none;
    width: 100%;
    margin-top: 16px;
    padding: 14px;
    background: var(--accent);
    border: none;
    border-radius: 10px;
    color: #0a0e1a;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .next-btn.show { display: block; animation: fadeIn 0.3s ease; }
  .next-btn:hover { opacity: 0.85; transform: translateY(-1px); }

  /* progress bar */
  .progress-bar-wrap {
    background: var(--surface2);
    border-radius: 4px;
    height: 4px;
    margin-bottom: 24px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    border-radius: 4px;
    transition: width 0.4s ease;
  }

  /* ── BROWSE MODE ── */
  .browse-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .browse-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .browse-item:hover { border-color: var(--muted); }

  .browse-header {
    padding: 16px 20px;
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .browse-q {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.5;
    flex: 1;
  }

  .browse-num {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    min-width: 50px;
  }

  .browse-toggle {
    font-size: 18px;
    color: var(--muted);
    transition: transform 0.3s;
    min-width: 24px;
    text-align: center;
  }

  .browse-item.open .browse-toggle { transform: rotate(180deg); }

  .browse-body {
    display: none;
    padding: 0 20px 20px;
    border-top: 1px solid var(--border);
  }

  .browse-item.open .browse-body { display: block; }

  .browse-answer {
    font-weight: 700;
    color: var(--accent);
    font-size: 14px;
    padding: 12px 0 8px;
  }

  .browse-explanation {
    font-size: 13px;
    color: #94a3b8;
    line-height: 1.7;
  }

  /* ── RESULTS ── */
  .results-screen {
    text-align: center;
    padding: 60px 40px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    display: none;
  }

  .results-screen.show { display: block; animation: slideIn 0.4s ease; }

  .results-score {
    font-size: 80px;
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 8px;
  }

  .results-label { font-size: 14px; color: var(--muted); margin-bottom: 32px; }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }

  .results-stat {
    background: var(--surface2);
    border-radius: 10px;
    padding: 20px;
  }

  .results-stat .val { font-size: 28px; font-weight: 800; }
  .results-stat .lbl { font-size: 12px; color: var(--muted); margin-top: 4px; font-family: 'Space Mono', monospace; }
  .correct-val { color: var(--correct); }
  .incorrect-val { color: var(--incorrect); }
  .skipped-val { color: var(--accent3); }

  .restart-btn {
    padding: 14px 40px;
    background: var(--accent);
    border: none;
    border-radius: 10px;
    color: #0a0e1a;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .restart-btn:hover { opacity: 0.85; transform: translateY(-2px); }

  /* ── SEARCH ── */
  .search-wrap {
    position: relative;
    margin-bottom: 20px;
  }

  .search-input {
    width: 100%;
    padding: 14px 20px 14px 48px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input:focus { border-color: var(--accent); }
  .search-input::placeholder { color: var(--muted); }

  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-size: 18px;
  }

  /* ── STUDIED INDICATOR ── */
  .studied-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--correct);
    display: inline-block;
    margin-left: 8px;
    vertical-align: middle;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .studied-dot.visible { opacity: 1; }

  /* Responsive */
  @media (max-width: 600px) {
    .mode-selector { grid-template-columns: 1fr; }
    .results-grid { grid-template-columns: 1fr; }
    .header-stats { display: none; }
    .card-question { font-size: 16px; }
  }
</style>
</head>
<body>

<header>
  <div class="logo">
    <div class="logo-icon">🧬</div>
    <div class="logo-text">
      <strong>Inżynieria Genetyczna</strong>
      Interaktywna baza egzaminacyjna
    </div>
  </div>
  <div class="header-stats">
    <div class="stat-chip">Pytań: <span id="totalCount">72</span></div>
    <div class="stat-chip">Przerobione: <span id="studiedCount">0</span></div>
    <div class="stat-chip">Wynik quiz: <span id="quizScore">—</span></div>
  </div>
</header>

<div class="app">

  <!-- MODE SELECTOR -->
  <div class="mode-selector">
    <button class="mode-btn active" onclick="setMode('flashcard')">
      <div class="mode-icon">🃏</div>
      <div class="mode-name">Fiszki</div>
      <div class="mode-desc">Przeglądaj pytania z odpowiedziami</div>
    </button>
    <button class="mode-btn" onclick="setMode('quiz')">
      <div class="mode-icon">⚡</div>
      <div class="mode-name">Quiz</div>
      <div class="mode-desc">Sprawdź wiedzę z wyborem odpowiedzi</div>
    </button>
    <button class="mode-btn" onclick="setMode('browse')">
      <div class="mode-icon">📚</div>
      <div class="mode-name">Przeglądaj</div>
      <div class="mode-desc">Wszystkie pytania z wyjaśnieniami</div>
    </button>
  </div>

  <!-- FILTER BAR -->
  <div class="filter-bar">
    <span class="filter-label">TEMAT:</span>
    <button class="tag active" onclick="setFilter('all', this)">Wszystkie</button>
    <button class="tag" onclick="setFilter('transkrypcja', this)">Transkrypcja</button>
    <button class="tag" onclick="setFilter('translacja', this)">Translacja</button>
    <button class="tag" onclick="setFilter('restrykcja', this)">Enzymy RM</button>
    <button class="tag" onclick="setFilter('plazmidy', this)">Plazmidy</button>
    <button class="tag" onclick="setFilter('wektory', this)">Wektory</button>
    <button class="tag" onclick="setFilter('metody', this)">Metody</button>
    <button class="tag" onclick="setFilter('open', this)">Otwarte</button>
  </div>

  <!-- FLASHCARD MODE -->
  <div id="flashcardMode">
    <div class="progress-bar-wrap">
      <div class="progress-bar-fill" id="flashProgress" style="width:0%"></div>
    </div>

    <div class="flashcard-container">
      <div class="flashcard" id="flashcard" onclick="flipCard()">
        <div class="card-face card-front" id="cardFront">
          <div class="card-number" id="cardNum">PYTANIE 01 / 72</div>
          <div id="cardTypeTag" class="card-tag mcq">MCQ</div>
          <div class="card-question" id="cardQuestion">Ładowanie...</div>
          <div class="card-hint">👆 Kliknij aby zobaczyć odpowiedź</div>
        </div>
        <div class="card-face card-back" id="cardBack">
          <div class="card-number" id="cardNumBack">PYTANIE 01 / 72</div>
          <div class="card-answer-label">ODPOWIEDŹ</div>
          <div class="card-answer" id="cardAnswer"></div>
          <div class="card-explanation" id="cardExplanation"></div>
        </div>
      </div>
    </div>

    <div class="card-nav">
      <button class="nav-btn" id="prevBtn" onclick="prevCard()" disabled>← Poprzednie</button>
      <span class="progress-text" id="progressText">1 / 72</span>
      <button class="nav-btn" id="nextBtn" onclick="nextCard()">Następne →</button>
    </div>

    <div class="rating-btns" id="ratingBtns" style="display:none">
      <button class="rating-btn easy" onclick="rateCard('easy')">✓ Znam</button>
      <button class="rating-btn medium" onclick="rateCard('medium')">~ Prawie</button>
      <button class="rating-btn hard" onclick="rateCard('hard')">✗ Nie wiem</button>
    </div>
  </div>

  <!-- QUIZ MODE -->
  <div id="quizMode" style="display:none">
    <div class="progress-bar-wrap">
      <div class="progress-bar-fill" id="quizProgress" style="width:0%"></div>
    </div>

    <div id="quizContainer">
      <div class="quiz-card" id="quizCard">
        <div class="card-number" id="quizNum">PYTANIE 1 / 10</div>
        <div class="quiz-question" id="quizQuestion"></div>
        <div class="options-grid" id="optionsGrid"></div>
        <div class="quiz-explanation" id="quizExplanation"></div>
        <button class="next-btn" id="nextQuizBtn" onclick="nextQuizQuestion()">Następne pytanie →</button>
      </div>
    </div>

    <div class="results-screen" id="resultsScreen">
      <div class="results-score" id="resultsScore">0%</div>
      <div class="results-label">Wynik quizu</div>
      <div class="results-grid">
        <div class="results-stat"><div class="val correct-val" id="correctCount">0</div><div class="lbl">Poprawnych</div></div>
        <div class="results-stat"><div class="val incorrect-val" id="incorrectCount">0</div><div class="lbl">Błędnych</div></div>
        <div class="results-stat"><div class="val skipped-val" id="quizTotal">0</div><div class="lbl">Łącznie</div></div>
      </div>
      <button class="restart-btn" onclick="startQuiz()">🔄 Nowy quiz</button>
    </div>
  </div>

  <!-- BROWSE MODE -->
  <div id="browseMode" style="display:none">
    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input class="search-input" type="text" placeholder="Szukaj pytania lub słowa kluczowego..." oninput="filterBrowse(this.value)" id="searchInput">
    </div>
    <div class="browse-grid" id="browseGrid"></div>
  </div>

</div>

<script>
// ─── DATA ────────────────────────────────────────────────────────────────────
const questions = [
